<div
  class="chromatic-border not-prose grid max-w-80 grid-cols-[auto_1fr]"
  data-nowplaying
>
  <div class="h-24 w-24" data-nowplaying-artwork></div>
  <div class="grid h-24 grid-rows-3 items-center p-2">
    <div
      class="overflow-hidden font-bold text-ellipsis whitespace-nowrap"
      data-nowplaying-name
    >
    </div>
    <div class="overflow-hidden text-sm text-ellipsis whitespace-nowrap">
      📀 <span data-nowplaying-album></span>
    </div>
    <div class="overflow-hidden text-sm text-ellipsis whitespace-nowrap">
      👤 <span data-nowplaying-artists></span>
    </div>
  </div>
</div>

<script>
  const REFRESH_INTERVAL_MS = 30000;

  interface SpotifyNowPlaying {
    album: {
      name?: string;
      url?: string;
    };
    artists: {
      name?: string;
      url?: string;
    }[];
    duration_ms?: number;
    images: {
      url: string;
      height: number | null;
      width: number | null;
    }[];
    is_playing?: boolean;
    name?: string;
    progress_ms?: number | null;
    url?: string;
  }

  function createImage(url: string | undefined) {
    const image = document.createElement("img");
    image.className = "h-full w-full object-cover";
    image.src = url ?? "";
    image.alt = "artwork";
    return image;
  }

  function createLink(name: string | undefined, url: string | undefined) {
    const link = document.createElement("a");
    link.className = "hover:underline";
    link.href = url ?? "";
    link.target = "_blank";
    link.rel = "noopener noreferrer";
    link.textContent = name ?? "";
    return link;
  }

  function clearNowPlaying() {
    artwork.replaceChildren();
    name.textContent = "No track playing";
    album.replaceChildren();
    artists.replaceChildren();
  }

  const container = document.querySelector("[data-nowplaying]")!;
  const artwork = container.querySelector("[data-nowplaying-artwork]")!;
  const name = container.querySelector("[data-nowplaying-name]")!;
  const album = container.querySelector("[data-nowplaying-album]")!;
  const artists = container.querySelector("[data-nowplaying-artists]")!;

  const fetchNowPlaying = () =>
    fetch("https://nowplaying.iwair.in")
      .then((res) => res.json())
      .then((nowPlaying: SpotifyNowPlaying) => {
        if (!nowPlaying.is_playing) {
          clearNowPlaying();
          return;
        }

        const artworkUrl = [...nowPlaying.images].sort(
          (a, b) =>
            Math.max(b.width ?? 0, b.height ?? 0) -
            Math.max(a.width ?? 0, a.height ?? 0),
        )[0].url;
        artwork.replaceChildren(createImage(artworkUrl));
        name.replaceChildren(createLink(nowPlaying.name, nowPlaying.url));
        album.replaceChildren(
          createLink(nowPlaying.album.name, nowPlaying.album.url),
        );
        artists.replaceChildren(
          ...nowPlaying.artists.reduce<Node[]>(
            (nodes, artist) => [
              ...nodes,
              ...(nodes.length > 0 ? [document.createTextNode(", ")] : []),
              createLink(artist.name, artist.url),
            ],
            [],
          ),
        );
      })
      .catch(() => {
        clearNowPlaying();
      })
      .finally(() => {
        window.setTimeout(fetchNowPlaying, REFRESH_INTERVAL_MS);
      });

  fetchNowPlaying();
</script>
