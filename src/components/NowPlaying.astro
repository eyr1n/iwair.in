<div
  class="chromatic-border not-prose grid max-w-80 grid-cols-[auto_1fr]"
  data-nowplaying
>
  <div class="h-24 w-24" data-nowplaying-artwork></div>
  <div class="grid h-24 grid-rows-3 items-center p-2">
    <div
      class="overflow-hidden font-bold text-ellipsis whitespace-nowrap"
      data-nowplaying-name
    >
    </div>
    <div class="overflow-hidden text-sm text-ellipsis whitespace-nowrap">
      📀 <span data-nowplaying-album></span>
    </div>
    <div class="overflow-hidden text-sm text-ellipsis whitespace-nowrap">
      👤 <span data-nowplaying-artists></span>
    </div>
  </div>
</div>

<script>
  interface SpotifyNowPlaying {
    album: {
      name?: string;
      url?: string;
    };
    artists: {
      name?: string;
      url?: string;
    }[];
    duration_ms?: number;
    images: {
      url: string;
      height: number | null;
      width: number | null;
    }[];
    is_playing?: boolean;
    name?: string;
    progress_ms?: number | null;
    url?: string;
  }

  const nowPlayingElement = document.querySelector("[data-nowplaying]")!;
  const artwork = nowPlayingElement.querySelector("[data-nowplaying-artwork]")!;
  const name = nowPlayingElement.querySelector("[data-nowplaying-name]")!;
  const album = nowPlayingElement.querySelector("[data-nowplaying-album]")!;
  const artists = nowPlayingElement.querySelector("[data-nowplaying-artists]")!;

  const createExternalLink = (
    href: string | undefined,
    text: string | undefined,
  ) => {
    const link = document.createElement("a");
    link.href = href ?? "";
    link.target = "_blank";
    link.rel = "noopener noreferrer";
    link.className = "hover:underline";
    link.textContent = text ?? "";

    return link;
  };

  const createArtworkImage = (src: string | undefined) => {
    const image = document.createElement("img");
    image.className = "h-full w-full object-cover";
    image.src = src ?? "";
    image.alt = "artwork";

    return image;
  };

  const createArtistLinks = (artistItems: SpotifyNowPlaying["artists"]) =>
    artistItems.flatMap((artist, index) => [
      ...(index > 0 ? [document.createTextNode(", ")] : []),
      createExternalLink(artist.url, artist.name),
    ]);

  const fetchNowPlaying = () =>
    fetch("https://nowplaying.iwair.in")
      .then((res) => res.json())
      .then((nowPlaying: SpotifyNowPlaying) => {
        if (nowPlaying.is_playing) {
          const artworkSrc = nowPlaying?.images.sort(
            (a, b) =>
              Math.max(b.width ?? 0, b.height ?? 0) -
              Math.max(a.width ?? 0, a.height ?? 0),
          )[0]?.url;

          artwork.replaceChildren(createArtworkImage(artworkSrc));
          name.replaceChildren(
            createExternalLink(nowPlaying.url, nowPlaying.name),
          );
          album.replaceChildren(
            createExternalLink(nowPlaying.album.url, nowPlaying.album.name),
          );
          artists.replaceChildren(...createArtistLinks(nowPlaying.artists));
        } else {
          artwork.replaceChildren();
          name.replaceChildren();
          album.replaceChildren();
          artists.replaceChildren();
        }
      })
      .then(() => window.setTimeout(fetchNowPlaying, 30000));

  fetchNowPlaying();
</script>
